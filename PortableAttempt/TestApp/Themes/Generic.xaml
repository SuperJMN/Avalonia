<avalonia:ResourceDictionary xmlns="https://github.com/grokys/Avalonia"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:avalonia="clr-namespace:Avalonia;assembly=Avalonia"
                    xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia"
                    xmlns:av="http://schemas.microsoft.com/winfx/2006/xaml/presentation">

    <avalonia:Style TargetType="{x:Type controls:ContentControl}">
        <avalonia:Style.Setters>
            <avalonia:Setter Property="Template">
                <avalonia:Setter.Value>
                    <controls:ControlTemplate TargetType="{x:Type controls:ContentControl}">
                        <controls:ControlTemplate.Template>
                            <controls:ContentPresenter/>
                        </controls:ControlTemplate.Template>
                    </controls:ControlTemplate>
                </avalonia:Setter.Value>
            </avalonia:Setter>
        </avalonia:Style.Setters>        
    </avalonia:Style>

    <avalonia:Style TargetType="{x:Type avalonia:Window}">
        <avalonia:Style.Setters>
            <avalonia:Setter Property="Template">
                <avalonia:Setter.Value>
                    <controls:ControlTemplate TargetType="{x:Type avalonia:Window}">
                        <controls:ControlTemplate.Template>
                            <controls:Border>
                                <controls:Border.Child>
                                    <controls:ContentPresenter /></controls:Border.Child>
                            </controls:Border></controls:ControlTemplate.Template>
                    </controls:ControlTemplate>
                </avalonia:Setter.Value>
            </avalonia:Setter></avalonia:Style.Setters>
    </avalonia:Style>

